# ============================================================
# AI Company Portfolio Site — 環境変数サンプル
# .env.local にコピーして値を設定してください
# ============================================================

# ---- Upstash Redis（レートリミット） -------------------------
# https://console.upstash.com/ でRedisデータベースを作成して取得
# 未設定時はインメモリフォールバックで動作
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# ---- Vercel Blob（受注ファイルのクラウド保存） ----------------
# Vercelダッシュボード → Storage → Blob で作成して取得
# 未設定時はローカルファイルシステムに保存
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token

# ---- Resend（メール通知） ------------------------------------
# https://resend.com/ でAPIキーを作成
# 未設定時はメール送信をスキップ（エラーにはならない）
RESEND_API_KEY=re_your_resend_api_key
